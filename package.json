  "pnpm": {
    "overrides": {
      "@codemirror/view": "6.43.0",
      "@codemirror/state": "6.5.2",
      "@codemirror/commands": "6.10.3"
    }
  },
  "packageManager": "pnpm@9.15.4"
}
